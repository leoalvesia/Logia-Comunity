FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat

# ── Install deps from monorepo root ───────────────────────────────────────
FROM base AS deps
WORKDIR /app
COPY package.json ./
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/ui-tokens/package.json    ./packages/ui-tokens/
COPY apps/web/package.json              ./apps/web/
RUN npm install --legacy-peer-deps

# ── Build ─────────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY packages/ ./packages/
COPY apps/web/  ./apps/web/

WORKDIR /app/apps/web

ENV NEXT_TELEMETRY_DISABLED 1

ARG NEXT_PUBLIC_API_URL=http://localhost:8001
ARG NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws
ARG NEXT_PUBLIC_MAPBOX_TOKEN
ARG NEXT_PUBLIC_STRIPE_PRICE_DISPLAY="R$ 97/mês"
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_MAPBOX_TOKEN=$NEXT_PUBLIC_MAPBOX_TOKEN
ENV NEXT_PUBLIC_STRIPE_PRICE_DISPLAY=$NEXT_PUBLIC_STRIPE_PRICE_DISPLAY

RUN npm run build

# ── Runtime ───────────────────────────────────────────────────────────────
FROM base AS runner
WORKDIR /app

ENV NODE_ENV production
ENV NEXT_TELEMETRY_DISABLED 1

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

# Copy the full app with node_modules and build output
COPY --from=builder --chown=nextjs:nodejs /app/node_modules        ./node_modules
COPY --from=builder --chown=nextjs:nodejs /app/packages            ./packages
COPY --from=builder --chown=nextjs:nodejs /app/apps/web            ./apps/web

USER nextjs

WORKDIR /app/apps/web

EXPOSE 3000
ENV PORT 3000
ENV HOSTNAME "0.0.0.0"

CMD ["npm", "start"]
