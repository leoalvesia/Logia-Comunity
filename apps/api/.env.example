# Copy to .env and fill in values.
# For Modal deployment: run `modal secret create logia-secrets` with the same keys.

# App
ENVIRONMENT=production
DEBUG=false
ALLOWED_ORIGINS=https://app.logiabusiness.com.br

# Database (Supabase PostgreSQL — free tier at supabase.com)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres

# Redis (Upstash — free tier at upstash.com)
REDIS_URL=rediss://:[password]@[host].upstash.io:6379

# JWT
JWT_SECRET=your-random-secret-here   # openssl rand -hex 32
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase (storage for avatars and post images)
SUPABASE_URL=https://[project].supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Email — Resend (free tier: 3k emails/month at resend.com)
RESEND_API_KEY=re_...
RESEND_FROM=noreply@logiabusiness.com.br

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
FRONTEND_URL=https://app.logiabusiness.com.br

# Google OAuth (configured through Supabase Auth dashboard — leave blank if using Supabase)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
